<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- TRIGGER LAYER -->
    <mxCell id="trigger_group" value="" style="group;" vertex="1" parent="1">
      <mxGeometry x="50" y="50" width="300" height="200" as="geometry"/>
    </mxCell>
    <mxCell id="trigger_bg" value="" style="rounded=1;fillColor=#f5f5f5;strokeColor=#cccccc;dashed=1;whiteSpace=wrap;" vertex="1" parent="trigger_group">
      <mxGeometry width="300" height="200" as="geometry"/>
    </mxCell>
    <mxCell id="trigger_title" value="Trigger Layer" style="text;align=left;fontStyle=1;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="trigger_group">
      <mxGeometry x="15" y="10" width="120" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="trigger_daily" value="ImportMarketDataJob&#xa;(Daily at Market Close)" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;whiteSpace=wrap;" vertex="1" parent="trigger_group">
      <mxGeometry x="20" y="45" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="trigger_ondemand" value="Account Sync&#xa;(On-Demand)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;" vertex="1" parent="trigger_group">
      <mxCell id="trigger_ondemand" value="Account Sync&#xa;(On-Demand)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;" vertex="1" parent="trigger_group">
      <mxGeometry x="160" y="45" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="trigger_runtime" value="Runtime Conversion&#xa;(Money#exchange_to)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;" vertex="1" parent="trigger_group">
      <mxGeometry x="90" y="125" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- IMPORTER LAYER -->
    <mxCell id="importer_group" value="" style="group;" vertex="1" parent="1">
      <mxGeometry x="50" y="300" width="300" height="200" as="geometry"/>
    </mxCell>
    <mxCell id="importer_bg" value="" style="rounded=1;fillColor=#f5f5f5;strokeColor=#cccccc;dashed=1;whiteSpace=wrap;" vertex="1" parent="importer_group">
      <mxGeometry width="300" height="200" as="geometry"/>
    </mxCell>
    <mxCell id="importer_title" value="Import Layer" style="text;align=left;fontStyle=1;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="importer_group">
      <mxGeometry x="15" y="10" width="120" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="market_importer" value="MarketDataImporter&#xa;(Determines required pairs)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;" vertex="1" parent="importer_group">
      <mxGeometry x="20" y="45" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="account_importer" value="Account::MarketDataImporter&#xa;(Single account pairs)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;" vertex="1" parent="importer_group">
      <mxGeometry x="160" y="45" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="rate_importer" value="ExchangeRate::Importer&#xa;- Fetch from Synth API&#xa;- 5-day buffer&#xa;- LOCF gapfilling&#xa;- Batch upsert (200/req)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;" vertex="1" parent="importer_group">
      <mxGeometry x="20" y="125" width="260" height="60" as="geometry"/>
    </mxCell>

    <!-- PROVIDER LAYER -->
    <mxCell id="provider_group" value="" style="group;" vertex="1" parent="1">
      <mxGeometry x="400" y="300" width="300" height="200" as="geometry"/>
    </mxCell>
    <mxCell id="provider_bg" value="" style="rounded=1;fillColor=#f5f5f5;strokeColor=#cccccc;dashed=1;whiteSpace=wrap;" vertex="1" parent="provider_group">
      <mxGeometry width="300" height="200" as="geometry"/>
    </mxCell>
    <mxCell id="provider_title" value="Provider Layer" style="text;align=left;fontStyle=1;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="provider_group">
      <mxGeometry x="15" y="10" width="120" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="provider_synth" value="Provider::Synth&#xa;- Faraday HTTP client&#xa;- Bearer token auth&#xa;- /rates/historical&#xa;- /rates/historical-range" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;whiteSpace=wrap;" vertex="1" parent="provider_group">
      <mxGeometry x="20" y="45" width="260" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="provider_registry" value="Provider::Registry&#xa(:exchange_rates => :synth)" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;whiteSpace=wrap;" vertex="1" parent="provider_group">
      <mxGeometry x="20" y="135" width="260" height="45" as="geometry"/>
    </mxCell>

    <!-- EXTERNAL API -->
    <mxCell id="synth_api" value="Synth Finance API&#xa;https://api.synthfinance.com&#xa;SYNTH_API_KEY" style="shape=cloud;whiteSpace=wrap;fillColor=#e6ffcc;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="450" y="50" width="200" height="100" as="geometry"/>
    </mxCell>

    <!-- DATABASE LAYER -->
    <mxCell id="db_group" value="" style="group;" vertex="1" parent="1">
      <mxGeometry x="50" y="550" width="300" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="db_bg" value="" style="rounded=1;fillColor=#f5f5f5;strokeColor=#cccccc;dashed=1;whiteSpace=wrap;" vertex="1" parent="db_group">
      <mxGeometry width="300" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="db_title" value="Storage Layer" style="text;align=left;fontStyle=1;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="db_group">
      <mxGeometry x="15" y="10" width="120" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="exchange_rates_db" value="exchange_rates&#xa;(base_currency, converted_currency, rate, date)" style="shape=cylinder3;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="db_group">
      <mxGeometry x="50" y="45" width="200" height="90" as="geometry"/>
    </mxCell>

    <!-- USAGE LAYER -->
    <mxCell id="usage_group" value="" style="group;" vertex="1" parent="1">
      <mxGeometry x="400" y="550" width="300" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="usage_bg" value="" style="rounded=1;fillColor=#f5f5f5;strokeColor=#cccccc;dashed=1;whiteSpace=wrap;" vertex="1" parent="usage_group">
      <mxGeometry width="300" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="usage_title" value="Usage Layer" style="text;align=left;fontStyle=1;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="usage_group">
      <mxGeometry x="15" y="10" width="120" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="money_class" value="Money#exchange_to&#xa;(Currency conversion)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;" vertex="1" parent="usage_group">
      <mxGeometry x="20" y="45" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="usage_components" value="Balance::SyncCache&#xa;Holding::PortfolioCache&#xa;Transfer::Creator&#xa;UI::Account::Chart" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;" vertex="1" parent="usage_group">
      <mxGeometry x="160" y="45" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="exchange_rate_model" value="ExchangeRate.find_or_fetch_rate&#xa;(DB lookup or live fetch fallback)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;" vertex="1" parent="usage_group">
      <mxGeometry x="20" y="115" width="260" height="45" as="geometry"/>
    </mxCell>

    <!-- EDGES: Trigger to Importer -->
    <mxCell id="e_trigger_daily_market" value="scheduled" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="trigger_daily" target="market_importer">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_trigger_ondemand_account" value="on sync" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="trigger_ondemand" target="account_importer">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_trigger_runtime_money" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="trigger_runtime" target="money_class">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGES: Importer to Provider -->
    <mxCell id="e_market_rateimporter" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="market_importer" target="rate_importer">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_account_rateimporter" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="account_importer" target="rate_importer">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_rateimporter_synth" value="fetch rates" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="rate_importer" target="provider_synth">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="350" y="455"/>
          <mxPoint x="420" y="455"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- EDGES: Provider to Synth API -->
    <mxCell id="e_synth_api" value="HTTP GET" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="provider_synth" target="synth_api">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGES: Importer to Database -->
    <mxCell id="e_rateimporter_db" value="upsert" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="rate_importer" target="exchange_rates_db">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="200" y="470"/>
          <mxPoint x="200" y="595"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- EDGES: Database to Usage -->
    <mxCell id="e_db_money" value="lookup rate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="exchange_rates_db" target="money_class">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGES: Money to ExchangeRate -->
    <mxCell id="e_money_exchangerate" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="money_class" target="exchange_rate_model">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGES: Money to Usage Components -->
    <mxCell id="e_money_usage" value="used by" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="money_class" target="usage_components">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGES: ExchangeRate to DB (fallback) -->
    <mxCell id="e_exchangerate_db" value="fallback fetch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;" edge="1" parent="1" source="exchange_rate_model" target="exchange_rates_db">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="150" y="690"/>
          <mxPoint x="150" y="595"/>
        </Array>
      </mxGeometry>
    </mxCell>

  </root>
</mxGraphModel>
