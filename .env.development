# --- App ---
SELF_HOSTED=false
PAYMENTS_ENABLED=false

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kuria_development

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/1
# CACHE_REDIS_URL=redis://127.0.0.1:6379/2

# --- AI (OpenCode Server) ---
# Rails connects to OpenCode running in Docker on localhost:4096
OPENCODE_SERVER_URL=http://localhost:4096
OPENCODE_SERVER_PASSWORD=
OPENCODE_DEFAULT_MODEL=qwen/qwen3.6-plus-free
MCP_AUTH_TOKEN=
OPENCODE_MCP_HOST=host.docker.internal
