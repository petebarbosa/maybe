# Self-hosting environment variables. For local dev, use .env.local.example instead.

# --- Required ---
SELF_HOSTED=true
SECRET_KEY_BASE=secret-value  # openssl rand -hex 64

# --- App ---
PORT=3000
APP_DOMAIN=
# DISABLE_SSL=true

# Disable Stripe/subscription billing entirely (all accounts treated as paid)
# PAYMENTS_ENABLED=false

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Email (optional) ---
SMTP_ADDRESS=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_ENABLED=true
EMAIL_SENDER=no-reply@kuria.com

# --- AI (OpenCode Server) ---
# Rails connects to OpenCode Server. Model should match a connected provider/model from OpenCode.
# Provider authentication is managed by OpenCode itself (via its own config or /provider OAuth).
# Rails does NOT require provider API keys.
OPENCODE_SERVER_URL=http://opencode:4096
OPENCODE_SERVER_PASSWORD=
OPENCODE_DEFAULT_MODEL=qwen/qwen3.6-plus-free
MCP_AUTH_TOKEN=
# For hybrid dev (Rails local, OpenCode in Docker), set to host.docker.internal
# For all-in-docker, leave as default (OpenCode resolves web service by name)
# OPENCODE_MCP_HOST=host.docker.internal

# --- Encryption keys (optional, auto-derived from SECRET_KEY_BASE if unset) ---
# Generate with: bin/rails db:encryption:init
# ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
# ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
# ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# --- Redis ---
# Used by Action Cable (WebSockets) and Sidekiq (background jobs)
REDIS_URL=redis://localhost:6379/1
# Optional: separate Redis instance for Rails cache store
CACHE_REDIS_URL=redis://localhost:6379/2

